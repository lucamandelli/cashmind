# Database
DATABASE_URL="postgresql://cashmind:cashmind@localhost:5432/cashmind"

# Auth (generate with: openssl rand -hex 32)
BETTER_AUTH_SECRET="change-me-in-production"
BETTER_AUTH_URL="http://localhost:3001"

# API
PORT=3001
NODE_ENV=development

# CORS — origin of the web app
WEB_ORIGIN="http://localhost:5173"

# Seed (only needed when running: npm run seed -w @cashmind/api)
SEED_USER_EMAIL="owner@example.com"
SEED_USER_PASSWORD="change-me-seed-password"
SEED_USER_NAME="Owner"
